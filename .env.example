# ============================================================
# JSL Client Portfolio Portal — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Generate JWT_SECRET with: openssl rand -hex 32
# ============================================================

# ── Database (REQUIRED) ──
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/client_portal
DATABASE_URL_SYNC=                          # Optional — auto-derived from DATABASE_URL if empty

# ── Auth (REQUIRED) ──
JWT_SECRET=                                 # REQUIRED — min 32 chars, generate with: openssl rand -hex 32
JWT_EXPIRY_HOURS=48                         # Optional — default 48, range 1-720

# ── Application (optional) ──
APP_NAME=JSL Client Portfolio Portal        # Optional — default shown
APP_PORT=8007                               # Optional — default 8007
APP_ENV=development                         # Optional — development | production
APP_VERSION=1.0.0                           # Optional — default 1.0.0
CORS_ORIGINS=http://localhost:3000          # Optional — comma-separated origins

# ── Risk Computation (optional) ──
RISK_FREE_RATE=6.50                         # Optional — India 10Y govt bond yield proxy (%)

# ── Logging (optional) ──
LOG_LEVEL=INFO                              # Optional — DEBUG | INFO | WARNING | ERROR
