# ============================================================
# JSL Client Portfolio Portal — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Generate JWT_SECRET with: openssl rand -hex 32
# ============================================================

# ── Database (REQUIRED) ──
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/client_portal
DATABASE_URL_SYNC=                          # Optional — auto-derived from DATABASE_URL if empty

# ── Auth (REQUIRED) ──
JWT_SECRET=                                 # REQUIRED — min 32 chars, generate with: openssl rand -hex 32
JWT_EXPIRY_HOURS=48                         # Optional — default 48, range 1-720

# ── Application (optional) ──
APP_NAME=JSL Client Portfolio Portal        # Optional — default shown
APP_PORT=8007                               # Optional — default 8007
# APP_ENV controls security headers: any value OTHER than "development"
# enables HSTS (Strict-Transport-Security) on every response. Set to
# "production" for deployed environments and "development" only for local
# HTTP testing. Startup fails fast if APP_ENV is blank.
APP_ENV=development                         # development | production | staging
APP_VERSION=1.0.0                           # Optional — default 1.0.0
# Comma-separated list of allowed CORS origins. Each entry must match
# ^https?://[a-z0-9.-]+(:\d+)?$ — wildcards are rejected. Startup fails if
# any entry is invalid; a warning is logged when more than one origin is
# configured in production.
CORS_ORIGINS=http://localhost:3000          # e.g. https://clients.jslwealth.in

# ── Risk Computation (optional) ──
RISK_FREE_RATE=6.50                         # Optional — India 10Y govt bond yield proxy (%)

# ── Logging (optional) ──
LOG_LEVEL=INFO                              # Optional — DEBUG | INFO | WARNING | ERROR
