# ══════════════════════════════════════════════
# JSL Client Portfolio Portal — Environment Config
# Copy to .env and fill in values
# ══════════════════════════════════════════════

# Database (RDS — fie-db instance)
DATABASE_URL=postgresql+asyncpg://fie_admin:YOUR_PASSWORD@fie-db.c7osw6q6kwmw.ap-south-1.rds.amazonaws.com:5432/client_portal
DATABASE_URL_SYNC=postgresql://fie_admin:YOUR_PASSWORD@fie-db.c7osw6q6kwmw.ap-south-1.rds.amazonaws.com:5432/client_portal

# Authentication
JWT_SECRET=                              # Generate: openssl rand -hex 32
JWT_EXPIRY_HOURS=48

# Application
APP_NAME=JSL Client Portfolio Portal
APP_PORT=8007
APP_ENV=development                      # development | production
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000       # Production: https://clients.jslwealth.in

# Risk Computation
RISK_FREE_RATE=6.50                      # India 10Y yield proxy (%)

# Logging
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                          # json | text
