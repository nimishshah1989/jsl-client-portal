# ══════════════════════════════════════════════
# JSL Client Portfolio Portal — Environment Config
# Copy to .env and fill in ALL values
# ══════════════════════════════════════════════

# Database
DATABASE_URL=postgresql+asyncpg://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME
DATABASE_URL_SYNC=postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME

# Authentication
JWT_SECRET=                              # Generate: openssl rand -hex 32
JWT_EXPIRY_HOURS=24

# PII Encryption (AES-256-GCM — field-level encryption for client PII)
ENCRYPTION_KEY=                          # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# Application
APP_NAME=JSL Client Portfolio Portal
APP_PORT=8007
APP_ENV=development                      # development | production
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000       # Production: https://clients.jslwealth.in

# Risk Computation
RISK_FREE_RATE=6.50                      # India 10Y yield proxy (%)

# Logging
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                          # json | text
